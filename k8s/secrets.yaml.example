# Copy this file to secrets.yaml and fill in the values
# kubectl apply -f secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: studio-secrets
type: Opaque
stringData:
  # App
  NEXT_PUBLIC_APP_URL: "https://studio.stevencreeks.com"

  # Auth0
  AUTH0_SECRET: ""
  AUTH0_BASE_URL: "https://studio.stevencreeks.com"
  AUTH0_ISSUER_BASE_URL: ""
  AUTH0_CLIENT_ID: ""
  AUTH0_CLIENT_SECRET: ""

  # Supabase
  NEXT_PUBLIC_SUPABASE_URL: ""
  NEXT_PUBLIC_SUPABASE_ANON_KEY: ""
  SUPABASE_SERVICE_ROLE_KEY: ""

  # Storage (B2/S3)
  S3_ENDPOINT: ""
  S3_BUCKET: ""
  S3_KEY: ""
  S3_SECRET: ""

  # AI Providers
  AI_FAL_KEY: ""
  AI_WAVESPEED: ""
  AI_ELEVEN_LABS: ""
  AI_ANTHROPIC: ""
  # AI_RUNWAY_ML: ""
  # AI_MODELS_LAB: ""
